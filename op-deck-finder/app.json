{
  "expo": {
    "name": "One Piece Deck Finder",
    "slug": "op-deck-finder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ED1D24"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.felipe.deckfinder"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ED1D24"
      },
      "package": "com.felipe.deckfinder"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "shortName": "DeckFinder",
      "backgroundColor": "#121212",
      "themeColor": "#ED1D24",
      "display": "standalone"
    }
  }
}